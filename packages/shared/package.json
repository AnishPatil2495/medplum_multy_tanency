    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8",
    "swagger-ui-express": "^5.0.1",
    "swagger-jsdoc": "^6.2.8",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@repo/config": "*",
    "@repo/logger": "*",
    "@repo/types": "*",
    "@repo/utils": "*",
    "@repo/tsconfig": "*",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
