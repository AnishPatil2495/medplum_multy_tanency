NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
APP_NAME=option1-project-per-tenant

# PostgreSQL
DATABASE_URL=postgresql://medplum:medplum_secret@localhost:5432/medplum_poc_app1

# JWT
JWT_SECRET=super-secret-jwt-key-at-least-32-chars-long!!
JWT_EXPIRES_IN=1h

# Medplum
MEDPLUM_BASE_URL=http://localhost:8103
MEDPLUM_SUPER_ADMIN_CLIENT_ID=your-super-admin-client-id
MEDPLUM_SUPER_ADMIN_CLIENT_SECRET=your-super-admin-client-secret

# Caching
CLIENT_CACHE_TTL_MS=300000

# CORS
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
