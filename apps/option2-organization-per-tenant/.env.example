NODE_ENV=development
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info
APP_NAME=option2-organization-per-tenant

# PostgreSQL
DATABASE_URL=postgresql://medplum:medplum_secret@localhost:5432/medplum_poc_app2

# JWT
JWT_SECRET=super-secret-jwt-key-at-least-32-chars-long!!
JWT_EXPIRES_IN=1h

# Medplum — shared single project
MEDPLUM_BASE_URL=http://localhost:8103
MEDPLUM_PROJECT_ID=your-shared-project-id
MEDPLUM_CLIENT_ID=your-client-id
MEDPLUM_CLIENT_SECRET=your-client-secret

# CORS
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
