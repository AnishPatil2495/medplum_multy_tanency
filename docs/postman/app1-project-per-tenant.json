{
  "info": {
    "_postman_id": "app1-project-per-tenant",
    "name": "App 1 — Project-per-Tenant",
    "description": "Demonstrates Medplum multi-tenancy via one Project per Tenant.\nAll requests (except Register Tenant and Health Check) require X-Tenant-ID header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "tenantSlug", "value": "acme-health" },
    { "key": "accessToken", "value": "" },
    { "key": "patientId", "value": "" },
    { "key": "practitionerId", "value": "" },
    { "key": "appointmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health",
        "description": "Returns server health status"
      }
    },
    {
      "name": "Tenant",
      "item": [
        {
          "name": "Register Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has tenant', () => pm.expect(json.data.tenant).to.be.an('object'));",
                  "pm.test('Has credentials', () => pm.expect(json.data.credentials.projectId).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tenants",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Health\",\n  \"slug\": \"acme-health\",\n  \"adminEmail\": \"admin@acme.com\",\n  \"adminPassword\": \"SecurePass123!\",\n  \"adminFirstName\": \"John\",\n  \"adminLastName\": \"Doe\",\n  \"subscription\": \"pro\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@acme.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"role\": \"practitioner\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "pm.test('Has access token', () => pm.expect(json.data.accessToken).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('patientId', json.data.id);",
                  "pm.test('Resource type is Patient', () => pm.expect(json.data.resourceType).to.equal('Patient'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/patients",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alice\",\n  \"lastName\": \"Johnson\",\n  \"birthDate\": \"1990-05-15\",\n  \"gender\": \"female\",\n  \"email\": \"alice@example.com\",\n  \"phone\": \"+1-555-0100\",\n  \"address\": {\n    \"line\": [\"123 Main St\"],\n    \"city\": \"Springfield\",\n    \"state\": \"IL\",\n    \"postalCode\": \"62701\",\n    \"country\": \"US\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+1-555-0199\"\n}"
            }
          }
        },
        {
          "name": "Search Patients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/patients?name=Alice&pageSize=10",
              "query": [
                { "key": "name", "value": "Alice" },
                { "key": "pageSize", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Practitioners",
      "item": [
        {
          "name": "Create Practitioner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('practitionerId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/practitioners",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Dr. Robert\",\n  \"lastName\": \"Chen\",\n  \"email\": \"dr.chen@acme.com\",\n  \"qualification\": \"MD, Cardiology\"\n}"
            }
          }
        },
        {
          "name": "Get Practitioner by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/practitioners/{{practitionerId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "List Practitioners",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/practitioners",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Create Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('appointmentId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/appointments",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"start\": \"2026-07-15T09:00:00Z\",\n  \"end\": \"2026-07-15T09:30:00Z\",\n  \"status\": \"booked\",\n  \"description\": \"Routine checkup\",\n  \"serviceType\": \"General Practice\"\n}"
            }
          }
        },
        {
          "name": "Get Appointment by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/appointments/{{appointmentId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "List Appointments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/appointments?status=booked&pageSize=20",
              "query": [
                { "key": "status", "value": "booked" },
                { "key": "pageSize", "value": "20" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "Search Appointments by Patient",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/appointments?patientId={{patientId}}",
              "query": [{ "key": "patientId", "value": "{{patientId}}" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "Update Appointment",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/appointments/{{appointmentId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"arrived\"\n}"
            }
          }
        }
      ]
    }
  ]
}
