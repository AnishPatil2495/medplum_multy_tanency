{
  "info": {
    "_postman_id": "app2-organization-per-tenant",
    "name": "App 2 — Organization-per-Tenant",
    "description": "Demonstrates Medplum multi-tenancy via FHIR Organization per Tenant.\nAll requests (except Register Tenant and Health Check) require X-Tenant-ID header.\nPatients automatically receive managingOrganization. Search is always org-scoped.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3002" },
    { "key": "tenantSlug", "value": "beta-clinic" },
    { "key": "accessToken", "value": "" },
    { "key": "patientId", "value": "" },
    { "key": "practitionerId", "value": "" },
    { "key": "appointmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Tenant",
      "item": [
        {
          "name": "Register Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has organizationId', () => pm.expect(json.data.credentials.organizationId).to.be.a('string'));",
                  "pm.test('No projectId needed', () => pm.expect(json.data.credentials.projectId).to.be.undefined);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tenants",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Beta Clinic\",\n  \"slug\": \"beta-clinic\",\n  \"adminEmail\": \"admin@betaclinic.com\",\n  \"adminPassword\": \"SecurePass123!\",\n  \"adminFirstName\": \"Mary\",\n  \"adminLastName\": \"Wong\",\n  \"subscription\": \"starter\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nurse@betaclinic.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"Carol\",\n  \"lastName\": \"Davis\",\n  \"role\": \"staff\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@betaclinic.com\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient (auto-scoped to Org)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('patientId', json.data.id);",
                  "pm.test('Has managingOrganization', () => pm.expect(json.data.managingOrganization).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/patients",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Bob\",\n  \"lastName\": \"Martinez\",\n  \"birthDate\": \"1985-03-22\",\n  \"gender\": \"male\",\n  \"email\": \"bob.martinez@example.com\"\n}"
            }
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "Search Patients (org-filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/patients?name=Bob",
              "query": [{ "key": "name", "value": "Bob" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+1-555-9999\"\n}"
            }
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Practitioners",
      "item": [
        {
          "name": "Create Practitioner (linked to Org via PractitionerRole)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('practitionerId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/practitioners",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Dr. Sarah\",\n  \"lastName\": \"Lee\",\n  \"email\": \"dr.lee@betaclinic.com\",\n  \"qualification\": \"MD, Family Medicine\"\n}"
            }
          }
        },
        {
          "name": "List Practitioners (org-filtered via PractitionerRole)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/practitioners",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Create Appointment (org-stamped)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('appointmentId', json.data.id);",
                  "pm.test('Has org extension', () => pm.expect(json.data.extension).to.be.an('array').with.length.greaterThan(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/appointments",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"practitionerId\": \"{{practitionerId}}\",\n  \"start\": \"2026-08-10T10:00:00Z\",\n  \"end\": \"2026-08-10T10:30:00Z\",\n  \"status\": \"booked\",\n  \"description\": \"Follow-up consultation\"\n}"
            }
          }
        },
        {
          "name": "List Appointments (org-filtered)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/appointments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Tenant-ID", "value": "{{tenantSlug}}" }
            ]
          }
        }
      ]
    }
  ]
}
